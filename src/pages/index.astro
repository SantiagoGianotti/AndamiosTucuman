---
import Layout from '../layouts/Layout.astro';

const whatsappNumber = '5493816938388';
const whatsappBase = `https://wa.me/${whatsappNumber}`;
const whatsappLink = `${whatsappBase}?text=${encodeURIComponent('Hola José! Necesito un presupuesto para alquiler de andamios/equipos. La obra está en [zona] y necesitaría arrancar [fecha aproximada].')}`;
const phone = '+54 9 3816 93-8388';

const servicios = [
  {
    title: 'Alquiler de Andamios',
    description: 'Andamios tubulares, de aluminio y torres móviles. Entrega y retiro en obra con disponibilidad inmediata, sin depender de terceros.',
    waText: 'Hola José! Necesito presupuesto para alquiler de andamios. La obra está en [zona] y necesitaría arrancar [fecha aproximada].',
    img: '/images/andamio-aluminio-local-comercial-tucuman.jpeg',
    imgAlt: 'Alquiler de andamios de aluminio en Tucumán',
  },
  {
    title: 'Reparación de Calles',
    description: 'Bacheo, hormigón y asfalto con maquinaria propia. Arrancamos en 24-48hs sin intermediarios para que tu obra no se demore.',
    waText: 'Hola José! Necesito presupuesto para reparación de calles. La obra está en [zona] y necesitaría arrancar [fecha aproximada].',
    img: '/images/vibrador-hormigon-maquinaria-propia.jpeg',
    imgAlt: 'Vibrador de hormigón para reparación de calles',
  },
  {
    title: 'Movimiento de Suelo',
    description: 'Nivelación y preparación de terrenos con retroexcavadoras y minicargadoras. Operadores capacitados y disponibilidad inmediata.',
    waText: 'Hola José! Necesito presupuesto para movimiento de suelo. La obra está en [zona] y necesitaría arrancar [fecha aproximada].',
    img: '/images/minicargadora-bobcat-alquiler-tucuman.jpeg',
    imgAlt: 'Minicargadora Bobcat para movimiento de suelo en Tucumán',
  },
  {
    title: 'Compactación de Terrenos',
    description: 'Compactación profesional para bases firmes y estables. Equipos disponibles de forma inmediata para cumplir tus plazos.',
    waText: 'Hola José! Necesito presupuesto para compactación de terrenos. La obra está en [zona] y necesitaría arrancar [fecha aproximada].',
    img: '/images/compactador-pata-cabra-obra-tucuman.jpeg',
    imgAlt: 'Compactador pata de cabra en obra en Tucumán',
  },
  {
    title: 'Albañilería y Mantenimiento',
    description: 'Obras de albañilería general y mantenimiento integral para proyectos residenciales, comerciales e industriales.',
    waText: 'Hola José! Necesito presupuesto para albañilería y mantenimiento. La obra está en [zona] y necesitaría arrancar [fecha aproximada].',
    img: '/images/equipo-trabajo-andamios-centro-comercial.jpeg',
    imgAlt: 'Equipo de trabajo en obra de mantenimiento comercial',
  },
  {
    title: 'Servicios Eléctricos',
    description: 'Instalaciones eléctricas y alumbrado para obras y espacios públicos o privados. Soluciones rápidas y eficientes.',
    waText: 'Hola José! Necesito presupuesto para servicios eléctricos. La obra está en [zona] y necesitaría arrancar [fecha aproximada].',
    img: '/images/tijera-elevadora-haulotte-alquiler.jpeg',
    imgAlt: 'Tijera elevadora para trabajos eléctricos en altura',
  },
];

const maquinaria = [
  'Andamios tubulares y de aluminio',
  'Tijeras elevadoras',
  'Martillos demoledores',
  'Cortadoras de hormigón',
  'Vibradores de hormigón',
  'Compactadoras',
  'Retroexcavadoras',
  'Minicargadoras',
  'Autoelevadores',
  'Camiones',
];

const materiales = [
  'Tierra',
  'Piedra',
  'Áridos en general',
  'Hierros',
  'Chapas',
  'Cemento',
  'Asfalto',
];

const galleryPhotos = [
  { src: '/images/andamio-tubular-rojo-edificio-moderno.jpeg', alt: 'Alquiler de andamio tubular rojo en edificio moderno en Tucumán', featured: true },
  { src: '/images/andamio-aluminio-local-comercial-tucuman.jpeg', alt: 'Andamio de aluminio en local comercial en Tucumán' },
  { src: '/images/equipo-trabajo-andamios-centro-comercial.jpeg', alt: 'Equipo de trabajo con andamios en centro comercial' },
  { src: '/images/andamio-rojo-pintura-mural-paisaje.jpeg', alt: 'Andamio rojo para pintura de mural en Tucumán' },
  { src: '/images/andamio-rojo-mural-aves-torre.jpeg', alt: 'Andamio en torre con mural artístico' },
  { src: '/images/torre-andamio-aluminio-exterior-altura.jpeg', alt: 'Torre de andamio de aluminio para trabajo en altura' },
  { src: '/images/minicargadora-bobcat-alquiler-tucuman.jpeg', alt: 'Alquiler de minicargadora Bobcat en Tucumán' },
  { src: '/images/tijera-elevadora-haulotte-alquiler.jpeg', alt: 'Alquiler de tijera elevadora Haulotte en Tucumán' },
  { src: '/images/vista-aerea-andamio-altura-tucuman.jpeg', alt: 'Vista aérea desde andamio en altura en Tucumán' },
  { src: '/images/trabajador-andamio-rojo-exterior-tucuman.jpeg', alt: 'Trabajador en andamio rojo en exterior' },
  { src: '/images/compactador-pata-cabra-obra-tucuman.jpeg', alt: 'Compactador pata de cabra en obra en Tucumán' },
  { src: '/images/andamio-aluminio-obra-residencial.jpeg', alt: 'Andamio de aluminio en obra residencial en Tucumán' },
  { src: '/images/andamio-mural-artistico-tucuman.jpeg', alt: 'Andamio para muralista en Tucumán' },
  { src: '/images/autoelevador-montacargas-alquiler.jpeg', alt: 'Alquiler de autoelevador montacargas en Tucumán' },
  { src: '/images/compactadora-placa-alquiler-tucuman.jpeg', alt: 'Alquiler de compactadora de placa en Tucumán' },
  { src: '/images/equipo-trabajadores-vidriera-comercial.jpeg', alt: 'Equipo de trabajadores en vidriera de local comercial' },
];

const faqs = [
  {
    q: '¿Cuánto cuesta alquilar un andamio en Tucumán?',
    a: 'El costo varía según el tipo de andamio, la altura requerida y la duración del alquiler. Ofrecemos presupuestos personalizados sin compromiso. Contactanos por WhatsApp para una cotización rápida.',
  },
  {
    q: '¿Qué incluye el servicio de alquiler?',
    a: 'Nuestro servicio incluye la entrega y retiro en obra del equipamiento. Contamos con andamios tubulares, de aluminio, tijeras elevadoras y más. Todo el equipo cuenta con mantenimiento al día.',
  },
  {
    q: '¿En qué zonas de Tucumán trabajan?',
    a: 'Cubrimos toda la provincia de Tucumán: San Miguel de Tucumán, Yerba Buena, Banda del Río Salí, Tafí Viejo, Las Talitas, Concepción y alrededores.',
  },
  {
    q: '¿Cuánto demoran en entregar el equipo?',
    a: 'Contamos con disponibilidad inmediata y maquinaria propia. En la mayoría de los casos podemos entregar en el día o dentro de las 24 horas.',
  },
];

const zonas = ['San Miguel de Tucumán', 'Yerba Buena', 'Banda del Río Salí', 'Tafí Viejo', 'Las Talitas', 'Concepción'];
---

<Layout
  title="Alquiler de Andamios en Tucumán | Maquinaria y Servicios para Obras"
  description="Alquiler de andamios, maquinaria y servicios integrales para obras en Tucumán y Yerba Buena. Maquinaria propia, disponibilidad inmediata. Pedí tu presupuesto por WhatsApp."
>
  <!-- Header / Nav -->
  <header id="site-header" class="fixed top-0 w-full bg-white/95 backdrop-blur-sm shadow-md z-50">
    <nav class="max-w-6xl mx-auto px-4 py-2 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo-tucuman-andamios-v1.jpeg" alt="Tucumán Andamios y Equipos - Logo" class="h-10 w-auto rounded-full" />
        <span class="hidden sm:inline text-lg font-bold text-slate-800 tracking-tight">Tucumán Andamios</span>
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex gap-6 text-sm font-medium">
        <a href="#inicio" class="hover:text-brand-blue transition-colors">Inicio</a>
        <a href="#servicios" class="hover:text-brand-blue transition-colors">Servicios</a>
        <a href="#trabajos" class="hover:text-brand-blue transition-colors">Trabajos</a>
        <a href="#maquinaria" class="hover:text-brand-blue transition-colors">Maquinaria</a>
        <a href="#faq" class="hover:text-brand-blue transition-colors">Preguntas</a>
        <a href="#contacto" class="hover:text-brand-blue transition-colors">Contacto</a>
      </div>

      <div class="flex items-center gap-3">
        <a
          href="#contacto"
          class="hidden md:inline-block bg-brand-gold hover:bg-brand-gold-light text-slate-900 text-sm font-bold px-5 py-2 rounded-lg transition-colors"
        >
          Pedir Presupuesto
        </a>

        <!-- Mobile hamburger -->
        <button
          id="menu-toggle"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
          aria-label="Abrir menú"
        >
          <span class="block w-6 h-0.5 bg-slate-800 transition-all" id="bar1"></span>
          <span class="block w-6 h-0.5 bg-slate-800 transition-all" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-slate-800 transition-all" id="bar3"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
      <div class="flex flex-col px-4 py-2">
        <a href="#inicio" class="py-3 border-b border-gray-100 font-medium hover:text-brand-blue transition-colors mobile-link">Inicio</a>
        <a href="#servicios" class="py-3 border-b border-gray-100 font-medium hover:text-brand-blue transition-colors mobile-link">Servicios</a>
        <a href="#trabajos" class="py-3 border-b border-gray-100 font-medium hover:text-brand-blue transition-colors mobile-link">Trabajos</a>
        <a href="#maquinaria" class="py-3 border-b border-gray-100 font-medium hover:text-brand-blue transition-colors mobile-link">Maquinaria</a>
        <a href="#faq" class="py-3 border-b border-gray-100 font-medium hover:text-brand-blue transition-colors mobile-link">Preguntas</a>
        <a href="#contacto" class="py-3 border-b border-gray-100 font-medium hover:text-brand-blue transition-colors mobile-link">Contacto</a>
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 mb-2 bg-green-500 hover:bg-green-600 text-white text-center font-bold py-3 rounded-lg transition-colors"
        >
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section id="inicio" class="relative min-h-[85vh] flex items-center scroll-mt-20">
      <img
        src="/images/andamio-tubular-rojo-edificio-moderno.jpeg"
        alt="Alquiler de andamios tubulares en obra comercial en Tucumán"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/30 md:to-transparent"></div>
      <div class="relative z-10 max-w-6xl mx-auto px-4 py-32 md:py-0 w-full">
        <div class="max-w-2xl text-center md:text-left">
          <p class="text-brand-gold-light font-semibold text-sm md:text-base uppercase tracking-widest mb-4">Más de 100 obras completadas en Tucumán</p>
          <h1 class="text-4xl md:text-6xl font-black leading-tight mb-6 text-white tracking-tight">
            Alquiler de Andamios<br />
            <span class="text-brand-gold-light">y Equipos en Tucumán</span>
          </h1>
          <p class="text-lg md:text-xl text-gray-300 mb-10 leading-relaxed">
            Tu obra no puede esperar. Disponibilidad inmediata, presupuesto en el día y cumplimiento de plazos garantizado.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-green-500 hover:bg-green-600 text-white font-bold px-8 py-4 rounded-xl text-lg transition-colors inline-flex items-center justify-center gap-2"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Pedí tu presupuesto ahora
            </a>
            <a
              href={`tel:${phone.replace(/\s/g, '')}`}
              class="border-2 border-white/30 hover:border-white/60 text-white font-bold px-8 py-4 rounded-xl text-lg transition-colors text-center inline-flex items-center justify-center gap-2"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              Llamanos ahora
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust Numbers Strip -->
    <section class="bg-slate-900 py-10 md:py-12">
      <div class="max-w-6xl mx-auto px-4 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div class="fade-in">
          <div class="text-3xl md:text-4xl font-black text-brand-gold-light mb-1">100+</div>
          <p class="text-gray-400 text-sm font-medium">Obras completadas</p>
        </div>
        <div class="fade-in" style="animation-delay: 0.1s">
          <div class="text-3xl md:text-4xl font-black text-brand-gold-light mb-1">24hs</div>
          <p class="text-gray-400 text-sm font-medium">Disponibilidad inmediata</p>
        </div>
        <div class="fade-in" style="animation-delay: 0.2s">
          <div class="text-3xl md:text-4xl font-black text-brand-gold-light mb-1">6+</div>
          <p class="text-gray-400 text-sm font-medium">Años de experiencia</p>
        </div>
        <div class="fade-in" style="animation-delay: 0.3s">
          <div class="text-3xl md:text-4xl font-black text-brand-gold-light mb-1">Tucumán</div>
          <p class="text-gray-400 text-sm font-medium">Cobertura provincial</p>
        </div>
      </div>
    </section>

    <!-- Services -->
    <section id="servicios" class="py-12 md:py-20 bg-slate-50 scroll-mt-20">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-2xl md:text-4xl font-bold text-center mb-4 tracking-tight">Servicios de Construcción y Alquiler de Equipos</h2>
        <p class="text-gray-600 text-center max-w-xl mx-auto mb-12 leading-relaxed">
          Personal capacitado y maquinaria propia para brindarte soluciones rápidas, eficientes y de calidad.
        </p>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {servicios.map((service, i) => (
            <div class="fade-in bg-white rounded-2xl shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col overflow-hidden group" style={`animation-delay: ${i * 0.1}s`}>
              <div class="relative h-48 overflow-hidden">
                <img
                  src={service.img}
                  alt={service.imgAlt}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
                <h3 class="absolute bottom-4 left-5 right-5 text-xl font-bold text-white tracking-tight drop-shadow-lg">{service.title}</h3>
              </div>
              <div class="p-5 md:p-6 flex flex-col flex-1">
                <p class="text-gray-600 leading-relaxed mb-4 flex-1">{service.description}</p>
                <a
                  href={`${whatsappBase}?text=${encodeURIComponent(service.waText)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-brand-blue hover:text-brand-blue-light text-sm font-semibold inline-flex items-center gap-1 transition-colors"
                >
                  Consultar por este servicio
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Photo Gallery -->
    <section id="trabajos" class="py-12 md:py-20 scroll-mt-20">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-2xl md:text-4xl font-bold text-center mb-4 tracking-tight">Nuestros Trabajos</h2>
        <p class="text-gray-600 text-center max-w-xl mx-auto mb-12 leading-relaxed">
          Obras comerciales, residenciales y espacios públicos en Tucumán y alrededores.
        </p>

        <!-- Desktop: Masonry grid -->
        <div class="hidden md:grid grid-cols-4 auto-rows-[200px] gap-4">
          {galleryPhotos.map((photo, i) => (
            <div class={`fade-in rounded-2xl overflow-hidden ${i === 0 ? 'col-span-2 row-span-2' : ''}`} style={`animation-delay: ${i * 0.05}s`}>
              <img
                src={photo.src}
                alt={photo.alt}
                class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
          ))}
        </div>

        <!-- Mobile: Horizontal scroll -->
        <div class="md:hidden gallery-scroll flex overflow-x-auto snap-x snap-mandatory gap-4 pb-4 -mx-4 px-4">
          {galleryPhotos.map((photo) => (
            <div class="snap-start flex-shrink-0 w-[280px] h-[380px] rounded-2xl overflow-hidden">
              <img
                src={photo.src}
                alt={photo.alt}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Maquinaria -->
    <section id="maquinaria" class="py-12 md:py-20 bg-slate-50 scroll-mt-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
          <div class="fade-in rounded-2xl overflow-hidden shadow-xl order-2 md:order-1">
            <img
              src="/images/torre-andamio-aluminio-exterior-altura.jpeg"
              alt="Alquiler de torre de andamio de aluminio para trabajo en altura en Tucumán"
              class="w-full h-[400px] md:h-[500px] object-cover"
              loading="lazy"
            />
          </div>
          <div class="order-1 md:order-2">
            <h2 class="text-2xl md:text-4xl font-bold mb-4 tracking-tight">Alquiler de Maquinaria en Tucumán</h2>
            <p class="text-gray-600 mb-2 leading-relaxed">
              Maquinaria propia para garantizar disponibilidad inmediata y cumplimiento de plazos. Entrega y retiro en obra.
            </p>
            <p class="text-gray-500 text-sm mb-6">Equipos con mantenimiento al día y cumplimiento de normas de seguridad.</p>
            <div class="space-y-3">
              {maquinaria.map((item) => (
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <span class="font-medium text-gray-800">{item}</span>
                </div>
              ))}
            </div>
            <a
              href={`${whatsappBase}?text=${encodeURIComponent('Hola José! Necesito presupuesto para alquiler de maquinaria. Necesito [tipo de equipo] para una obra en [zona].')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 mt-8 text-brand-blue hover:text-brand-blue-light font-semibold transition-colors"
            >
              ¿Necesitás algo que no ves? Consultanos
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Materiales -->
    <section class="py-12 md:py-20 scroll-mt-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
          <div>
            <h2 class="text-2xl md:text-4xl font-bold mb-4 tracking-tight">Materiales para Construcción</h2>
            <p class="text-gray-600 mb-8 leading-relaxed">
              Provisión de materiales según necesidad. Disponemos de todo lo que tu obra requiere, con entrega en obra.
            </p>
            <div class="flex flex-wrap gap-3">
              {materiales.map((item) => (
                <div class="flex items-center gap-2 bg-blue-50 text-blue-900 rounded-lg px-4 py-3 font-medium">
                  <svg class="w-4 h-4 text-brand-blue flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  {item}
                </div>
              ))}
            </div>
            <a
