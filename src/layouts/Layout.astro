---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpeg" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="es-AR" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1a5fb4" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Tucumán Andamios y Equipos" />
    <meta property="og:image" content="https://andamiostucuman.com.ar/images/og-image.jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://andamiostucuman.com.ar/images/og-image.jpeg" />

    <!-- Geo -->
    <meta name="geo.region" content="AR-T" />
    <meta name="geo.placename" content="Yerba Buena, Tucumán" />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Tucumán Andamios y Equipos",
      "description": "Alquiler de andamios, maquinaria y servicios integrales para obras y construcción en Tucumán. Maquinaria propia, materiales y personal capacitado.",
      "url": "https://andamiostucuman.com.ar",
      "telephone": "+54 9 3816 93-8388",
      "email": "contacto@andamiostucuman.com.ar",
      "image": "https://andamiostucuman.com.ar/images/logo-tucuman-andamios-v1.jpeg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Yerba Buena",
        "addressRegion": "Tucumán",
        "addressCountry": "AR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -26.8167,
        "longitude": -65.2833
      },
      "areaServed": [
        { "@type": "City", "name": "San Miguel de Tucumán" },
        { "@type": "City", "name": "Yerba Buena" },
        { "@type": "City", "name": "Banda del Río Salí" },
        { "@type": "City", "name": "Tafí Viejo" },
        { "@type": "City", "name": "Las Talitas" },
        { "@type": "City", "name": "Concepción" }
      ],
      "sameAs": ["https://www.instagram.com/tucuman.andamios/"],
      "serviceType": [
        "Alquiler de andamios",
        "Alquiler de maquinaria para construcción",
        "Reparación de calles",
        "Movimiento de suelo",
        "Compactación de terrenos",
        "Albañilería y mantenimiento",
        "Servicios eléctricos y alumbrado"
      ]
    })} />

    <!-- Structured Data: FAQPage -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "¿Cuánto cuesta alquilar un andamio en Tucumán?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "El costo varía según el tipo de andamio, la altura requerida y la duración del alquiler. Ofrecemos presupuestos personalizados sin compromiso. Contactanos por WhatsApp para una cotización rápida."
          }
        },
        {
          "@type": "Question",
          "name": "¿Qué incluye el servicio de alquiler de andamios?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Nuestro servicio incluye la entrega y retiro en obra del equipamiento. Contamos con andamios tubulares, de aluminio, tijeras elevadoras y más. Todo el equipo cuenta con mantenimiento al día."
          }
        },
        {
          "@type": "Question",
          "name": "¿En qué zonas de Tucumán trabajan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cubrimos toda la provincia de Tucumán: San Miguel de Tucumán, Yerba Buena, Banda del Río Salí, Tafí Viejo, Las Talitas, Concepción y alrededores."
          }
        },
        {
          "@type": "Question",
          "name": "¿Cuánto demoran en entregar el equipo?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Contamos con disponibilidad inmediata y maquinaria propia. En la mayoría de los casos podemos entregar en el día o dentro de las 24 horas."
          }
        }
      ]
    })} />

    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-gray-800 font-sans antialiased">
    <slot />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
